# ============================================================
# WP Express VPS Infrastructure — Environment Configuration
# Copy to .env and fill in all values before running bootstrap
# ============================================================

# --- VPS connection ---
VPS_HOST=                         # IP or hostname of your Hetzner VPS
VPS_SSH_USER=deploy               # User created by bootstrap-vps.sh
VPS_SSH_KEY=~/.ssh/id_rsa         # Path to SSH private key

# --- Let's Encrypt ---
ACME_EMAIL=admin@webdeveloping.hu

# --- Base domain (wildcard *.BASE_DOMAIN must point to VPS IP) ---
BASE_DOMAIN=webdeveloping.hu

# --- Traefik dashboard credentials ---
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=changeme   # plain text; bootstrap hashes it

# --- MariaDB root passwords (auto-generated by bootstrap if left empty) ---
MARIADB_PROD_ROOT_PASSWORD=
MARIADB_STAGING_ROOT_PASSWORD=

# --- Hetzner Object Storage (for automated DB backups) ---
# Create a bucket at https://console.hetzner.cloud → Object Storage
# API keys: https://console.hetzner.cloud → Security → API Tokens (S3 credentials)
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_ACCESS_KEY=
HETZNER_S3_SECRET_KEY=
HETZNER_S3_BUCKET=wp-express-backups

# --- SSH deploy user ---
DEPLOY_USER=deploy
