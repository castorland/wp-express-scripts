[mysqld]
# ============================================================
# Shared Production MariaDB — Tuned for 8 GB VPS, multi-client
# ============================================================

# Security
skip_name_resolve          = 1
local_infile               = 0
symbolic_links             = 0

# Character set
character_set_server       = utf8mb4
collation_server           = utf8mb4_unicode_ci

# InnoDB — allocate ~25% of RAM to buffer pool
innodb_buffer_pool_size    = 2G
innodb_buffer_pool_instances = 2
innodb_log_file_size       = 256M
# 2 = write to log only, flush once per second (faster, tiny durability trade-off)
innodb_flush_log_at_trx_commit = 2
innodb_flush_method        = O_DIRECT
innodb_file_per_table      = 1

# Connections
max_connections            = 200
thread_cache_size          = 16
wait_timeout               = 300
interactive_timeout        = 300

# Query / temp tables
tmp_table_size             = 64M
max_heap_table_size        = 64M
join_buffer_size           = 2M
sort_buffer_size           = 4M
read_rnd_buffer_size       = 2M
table_open_cache           = 2000

# Slow query log (helps identify WordPress query issues)
slow_query_log             = 1
slow_query_log_file        = /var/lib/mysql/slow.log
long_query_time            = 1

# Disable query cache (deprecated, harmful under load)
query_cache_type           = 0
query_cache_size           = 0

[client]
default-character-set      = utf8mb4

[mysql]
default-character-set      = utf8mb4
