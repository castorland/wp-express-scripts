[mysqld]
# ============================================================
# Shared Staging MariaDB — Lightweight config, same VPS
# ============================================================

# Security
skip_name_resolve          = 1
local_infile               = 0
symbolic_links             = 0

# Character set
character_set_server       = utf8mb4
collation_server           = utf8mb4_unicode_ci

# InnoDB — small footprint for staging
innodb_buffer_pool_size    = 512M
innodb_log_file_size       = 64M
innodb_flush_log_at_trx_commit = 2
innodb_file_per_table      = 1

# Connections — fewer needed for staging
max_connections            = 50
thread_cache_size          = 8
wait_timeout               = 300
interactive_timeout        = 300

# Query / temp tables
tmp_table_size             = 32M
max_heap_table_size        = 32M

# Disable query cache
query_cache_type           = 0
query_cache_size           = 0

[client]
default-character-set      = utf8mb4

[mysql]
default-character-set      = utf8mb4
